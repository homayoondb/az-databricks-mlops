# Databricks notebook source
"""Batch agent invocation using the champion model from Unity Catalog.

Loads the agent with the @champion alias, processes the input table,
and writes responses to the output table.
"""

import mlflow

# COMMAND ----------

dbutils.widgets.text("model_name", "")
dbutils.widgets.text("input_table_name", "")
dbutils.widgets.text("output_table_name", "")

model_name = dbutils.widgets.get("model_name")
input_table_name = dbutils.widgets.get("input_table_name")
output_table_name = dbutils.widgets.get("output_table_name")

# COMMAND ----------

model = mlflow.pyfunc.load_model(f"models:/{model_name}@champion")
print(f"Loaded agent: {model_name}@champion")

# COMMAND ----------

# Enable tracing in production for observability.
mlflow.tracing.enable()

input_df = spark.table(input_table_name).toPandas()
responses = input_df["input"].apply(lambda x: model.predict(x))

# COMMAND ----------

output_df = input_df.copy()
output_df["response"] = responses
spark.createDataFrame(output_df).write.mode("overwrite").saveAsTable(output_table_name)
print(f"Wrote {len(output_df)} responses to {output_table_name}")
