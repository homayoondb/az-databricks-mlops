bundle:
  name: {{ project_name }}

variables:
  experiment_name:
    description: MLflow experiment path for model training.
    default: /Shared/az-databricks-mlops/${bundle.target}-{{ project_name }}-experiment

  schema_name:
    description: Unity Catalog schema (database) where the model is registered.
    default: {{ schema_name }}

  model_name:
    description: Registered model name in Unity Catalog.
    default: {{ project_name | replace('-', '_') }}

  catalog_name:
    description: Unity Catalog catalog name (maps to environment).

sync:
  include:
{%- if project_type == "llmops" %}
    - "llmops/**"
{%- else %}
    - "mlops/**"
{%- endif %}
    - "**/*.py"
    - "**/*.ipynb"
    - "data/**"

include:
{%- if project_type == "llmops" %}
  - ./resources/agent-job.yml
{%- if with_serving %}
  - ./resources/agent-serve-job.yml
{%- endif %}
{%- else %}
  - ./resources/training-job.yml
{%- if with_inference %}
  - ./resources/inference-job.yml
{%- endif %}
{%- if with_dqx %}
  - ./resources/dqx-job.yml
{%- endif %}
{%- endif %}

targets:
  dev:
    mode: development
    default: true
    variables:
      catalog_name: {{ catalog_name }}
    workspace:
      host: {{ staging_workspace_url }}

  staging:
    variables:
      catalog_name: {{ catalog_name }}
    workspace:
      host: {{ staging_workspace_url }}
{% if prod_workspace_url %}
  prod:
    variables:
      catalog_name: {{ catalog_name }}
    workspace:
      host: {{ prod_workspace_url }}
{%- endif %}
